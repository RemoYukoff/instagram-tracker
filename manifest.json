{
  "manifest_version": 3,
  "name": "Instagram Tracker",
  "version": "1.0.0",
  "description": "Local-only tracker for who doesn't follow you back on Instagram, and who unfollowed you.",
  "permissions": ["cookies"],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://*.cdninstagram.com/*",
    "https://*.fbcdn.net/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Instagram Tracker (click to open results)"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  }
}
